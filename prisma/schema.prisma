generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  senha           String
  nome            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  reservas        ReservaEmergencia[]
  entradas        Entrada[]
  saidas          Saida[]
  contasMensais  ContaMensal[]
}

model ContaMensal {
  id            String   @id @default(cuid())
  nome          String
  valor         Float
  dataVencimento Int
  mes           Int
  ano           Int
  status        StatusConta @default(PENDENTE)
  tipo          TipoConta
  fixa          Boolean  @default(false)
  parcelada     Boolean  @default(false)
  parcelaAtual  Int      @default(1)
  totalParcelas Int      @default(1)
  observacoes   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  usuarioId     String
  usuario       User     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}

model Entrada {
  id          String   @id @default(cuid())
  descricao   String
  valor       Float
  data        DateTime @default(now())
  categoria   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  usuarioId   String
  usuario     User     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}

model Saida {
  id              String   @id @default(cuid())
  descricao       String
  valor           Float
  data            DateTime @default(now())
  categoria       String
  contaVinculadaId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  usuarioId       String
  usuario         User     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}

model ReservaEmergencia {
  id          String   @id @default(cuid())
  valor       Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  usuarioId   String
  usuario     User     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  transacoes  TransacaoReserva[]
}

model TransacaoReserva {
  id        String   @id @default(cuid())
  tipo      TipoTransacaoReserva
  valor     Float
  data      DateTime @default(now())
  reservaId String
  reserva   ReservaEmergencia @relation(fields: [reservaId], references: [id], onDelete: Cascade)
}

enum StatusConta {
  PENDENTE
  PAGA
  ATRASADA
}

enum TipoConta {
  CONTAS_FIXAS
  CONTAS_VARIAS
  ASSINATURAS
  OUTROS
}

enum TipoTransacaoReserva {
  DEPOSITO
  SAQUE
}
